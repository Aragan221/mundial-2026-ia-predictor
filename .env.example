# ===========================================================================
# API-Football (API-SPORTS) - https://dashboard.api-football.com
# Copia este archivo como .env.local y pega tu API key real.
# NUNCA subas tu .env.local a GitHub (ya esta en .gitignore).
# ===========================================================================

# Tu API key de API-Football (registro directo en api-football.com)
API_FOOTBALL_KEY=pega_aqui_tu_api_key

# Host de la API.
#   - Registro directo (api-football.com):  v3.football.api-sports.io
#   - Via RapidAPI:                          api-football-v1.p.rapidapi.com
API_FOOTBALL_HOST=v3.football.api-sports.io

# Pon "rapidapi" si te registraste por RapidAPI, o "direct" si fue por la web oficial.
API_FOOTBALL_PROVIDER=direct
